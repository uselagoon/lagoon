{
  "name": "auth-server",
  "version": "1.0.0",
  "author": "amazee.io <hello@amazee.io> (http://www.amazee.io)",
  "license": "MIT",
  "contributors": [
    "Patrick Stapfer <patrick@amazee.io>",
    "Karl Horky <karl.horky@gmail.com>",
    "Michael Schmid <michael@amazee.io> (https://amazee.io)"
  ],
  "main": "dist/index.js",
  "scripts": {
    "clean": "rimraf dist && rimraf logs",
    "build": "tsc --build",
    "start": "node dist/index",
    "dev": "NODE_ENV=development nodemon",
    "format": "prettier-eslint --write '**/*.js'",
    "lint": "eslint ."
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "js,ts,json",
    "exec": "pnpm build && pnpm start --inspect=0.0.0.0:9229"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "body-parser": "^1.20.4",
    "express": "^4.22.1",
    "jsonwebtoken": "^8.5.1",
    "morgan": "^1.10.1",
    "ramda": "0.25.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "prettier-eslint-cli": "^8.0.1",
    "typescript": "^5.9.3"
  }
}
