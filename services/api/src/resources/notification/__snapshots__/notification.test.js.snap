exports[`Sql deleteProjectNotification should create a proper query 1`] = `
"DELETE pn
      FROM project_notification as pn
      LEFT JOIN \`notification_slack\` AS nt ON pn.nid = nt.id AND pn.type = 'slack'
      LEFT JOIN project as p on pn.pid = p.id
      WHERE p.name = 'some_project'
      AND nt.name = 'some_slack'"
`;

exports[`Sql selectAssignedProjectNotificationByName should create proper statement 1`] = `"select \`nt\`.*, \`pn\`.*, 'slack' as orig_type from \`project_notification\` as \`pn\` JOIN notification_slack AS nt ON pn.nid = nt.id AND pn.type = 'slack' and pn.content_type = 'deployment' where \`nt\`.\`name\` = 'slack_foo'"`;

exports[`Sql selectCustomer should create a proper query 1`] = `"select * from \`notification_slack\` where \`name\` = 'n1'"`;

exports[`Sql selectNotificationsByTypeByProjectId should create a proper query 1`] = `"select \`nt\`.*, \`pn\`.\`type\`, \`pn\`.\`content_type\` as \`content_type\`, \`pn\`.\`notification_severity_threshold\` as \`notification_severity_threshold\` from \`project_notification\` as \`pn\` JOIN notification_slack AS nt ON pn.nid = nt.id AND pn.type = 'slack' AND pn.content_type = 'deployment' where \`pn\`.\`pid\` = 3 and \`pn\`.\`notification_severity_threshold\` >= 0"`;

exports[`Sql updateNotificationSlack should create a proper query 1`] = `"update \`notification_slack\` set \`name\` = 'test', \`webhook\` = 'new-webhook' where \`name\` = 'n1'"`;
